# ---- Stage 1: Dependencies ----
    FROM node:18-alpine AS deps
    RUN npm install -g pnpm
    WORKDIR /app
    COPY pnpm-lock.yaml pnpm-workspace.yaml ./
    COPY package.json ./
    COPY apps/backend/package.json ./apps/backend/package.json
    # If you have shared packages, copy them too
    # COPY packages/*/package.json ./packages/
    RUN pnpm install --frozen-lockfile
    
    # ---- Stage 2: Builder ----
    FROM node:18-alpine AS builder
    RUN npm install -g pnpm turbo
    WORKDIR /app
    COPY . .
    # Copy dependencies from deps stage (preserves node_modules)
    COPY --from=deps /app/node_modules ./node_modules
    COPY --from=deps /app/apps/backend/node_modules ./apps/backend/node_modules
    
    # Build only backend with Turborepo
    RUN turbo run build --filter=backend
    
    # ---- Stage 3: Runner ----
    FROM node:18-alpine AS runner
    WORKDIR /app
    # Create non-root user
    RUN addgroup --system --gid 1001 nodejs && \
        adduser --system --uid 1001 nodejs
    USER nodejs
    
    # Copy built backend
    COPY --from=builder --chown=nodejs:nodejs /app/apps/backend/dist ./dist
    COPY --from=builder --chown=nodejs:nodejs /app/apps/backend/package.json ./package.json
    COPY --from=builder --chown=nodejs:nodejs /app/apps/backend/node_modules ./node_modules
    
    EXPOSE 5000
    CMD ["node", "dist/server.js"]