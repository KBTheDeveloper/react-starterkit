{
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5",
    "useTabs": false,
    "tabWidth": 2,
    "printWidth": 80,
    "importOrder": [
        "^(react/(.*)$)|^(react$)|effector",
        "<THIRD_PARTY_MODULES>",
        "^@/(.*)$",
        "^[./]"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
}